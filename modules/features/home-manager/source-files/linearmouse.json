{
  "$schema" : "https:\/\/schema.linearmouse.app\/0.11.1",
  "schemes" : [
    {
      "buttons" : {
        "mappings" : [
          {
            "action" : "mouse.button.left",
            "button" : 0,
            "command" : false,
            "control" : true,
            "option" : false,
            "shift" : false
          },
	  {
            "action" : "mouse.wheel.scrollDown",
            "command" : false,
            "control" : false,
            "option" : false,
            "scroll" : "down",
            "shift" : true
          },
          {
            "action" : "mouse.wheel.scrollUp",
            "command" : false,
            "control" : false,
            "option" : false,
            "scroll" : "up",
            "shift" : true
          }
        ]
      },
      "if" : {
        "device" : {
          "category" : "mouse",
          "productID" : "0xc548",
          "productName" : "USB Receiver",
          "vendorID" : "0x46d"
        }
      },
      "pointer" : {
        "acceleration" : 0.612,
        "disableAcceleration" : true
      },
      "scrolling" : {
        "acceleration" : 1,
        "distance" : 4,
        "reverse" : true,
        "smoothed" : {
          "enabled" : false
        },
        "speed" : 0
      }
    }
  ]
}
